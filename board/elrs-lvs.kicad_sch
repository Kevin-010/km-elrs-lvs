	(text "Goal: Linear 0-27v (6s)\nSafe -27-27v (TODO find max pin current)\nnonlinear to ~-5v-35v (one cell off, ground lift, etc)\n\nADC_ATTEN_DB_0 100 mV ~ 950 mV (common, default prior to supporting vbat_atten)\nADC_ATTEN_DB_2_5 100 mV ~ 1250 mV\nADC_ATTEN_DB_6 150 mV ~ 1750 mV\nADC_ATTEN_DB_11 150 mV ~ 3100 mV (common) nonlinear after ~2.6v"
		(exclude_from_sim no)
